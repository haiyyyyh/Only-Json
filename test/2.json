{
    "editor.fontWeight": "normal",
    "editor.fontFamily": "'Maple Mono','Symbols Nerd Font'",
    "explorer.confirmDelete": false,
    "hexeditor.columnWidth": 16,
    "hexeditor.showDecodedText": true,
    "terminal.integrated.fontFamily": "'Maple Mono','MesloLGS NF'",
    "workbench.secondarySideBar.defaultVisibility": "hidden",
    "window.newWindowProfile": "默认",
    "window.confirmSaveUntitledWorkspace": false,
    "editor.formatOnSave": false,
    "editor.minimap.showSlider": "always",
    "workbench.panel.showLabels": false,
    "workbench.secondarySideBar.showLabels": false,
    "workbench.activityBar.location": "top",
    "git.openRepositoryInParentFolders": "never",
    "workbench.colorTheme": "Field Lights",
    "workbench.editor.wrapTabs": true,
    "rust-analyzer.restartServerOnConfigChange": true,
    "rust-analyzer.showSyntaxTree": true,
    "rust-analyzer.checkOnSave": false,
    "[cpp]": {
        "version" : 23
    },
    "files.associations": {
        ".clang-format": "yaml",
        ".clangd": "yaml",
        "*.rp": "log",
        "*.cmake": "cmake",
        ".clang-tidy": "yaml"
    },
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.typeEvaluation.enableReachabilityAnalysis": true,
    "python.analysis.useNearestConfiguration": true,
    "python.analysis.inlayHints.functionReturnTypes": true,
    "go.formatTool": "gofmt",
    "C_Cpp.errorSquiggles": "enabled",
    "C_Cpp.loggingLevel": "Debug",
    "C_Cpp.windowsErrorReportingMode": "enabled",
    "C_Cpp.codeAnalysis.runAutomatically": false,
    "C_Cpp.default.cppStandard": "c++23",
    "C_Cpp.default.cStandard": "c23",
    "liveServer.settings.donotShowInfoMsg": true,
    "redhat.telemetry.enabled": true,
    "svg.preview.mode": "svg",
    "workbench.editorAssociations": {
        "{hexdiff}:/**/*.*": "hexEditor.hexedit",
        "*.svg": "default"
    },
